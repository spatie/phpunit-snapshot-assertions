#!/usr/bin/env php
<?php

/*
 * This wrapper sets the CREATE_SNAPSHOTS=false environment variable and then runs
 * PHPUnit, so missing snapshots cause the run to fail instead of being created.
 *
 * It exists because the previously documented syntax (`phpunit -d --without-creating-snapshots`)
 * abuses PHPUnit's `-d` flag, which is meant to set php.ini values. Since PHPUnit
 * 12.5.12 (https://github.com/sebastianbergmann/phpunit/commit/87f68b9), failed
 * ini_set() calls produce a visible test runner warning, surfacing that misuse.
 */

// Set in all three locations so getenv(), $_ENV[] and $_SERVER[] reads all see the value,
// regardless of the user's `variables_order` ini setting.
putenv('CREATE_SNAPSHOTS=false');
$_ENV['CREATE_SNAPSHOTS'] = 'false';
$_SERVER['CREATE_SNAPSHOTS'] = 'false';

require __DIR__.'/_run-phpunit.php';
